# ─── Discord Tokens (Multi-Account) ────────────────────
# Minimum 1 token required. Add TOKEN_2, TOKEN_3, etc. for more accounts.
TOKEN_1=
TOKEN_2=
TOKEN_3=

# ─── Prefix Per Account ────────────────────────────────
# Each account can have its own prefix. Fallback: !
PREFIX_1=!
PREFIX_2=.
PREFIX_3=,

# ─── Dashboard ──────────────────────────────────────────
PORT=3000
APP_USER=admin
APP_PASS=change_this_password
DASHBOARD_ACCOUNT=1 # Which account number (1, 2, or 3) to use for the dashboard and music player

# ─── Lavalink v4 (Music) ───────────────────────────────
# Leave empty to disable music features
LAVALINK_WS=
LAVALINK_REST=
LAVALINK_PASSWORD=
CLIENT_NAME=HymnPlus

# ─── AI Chat (NVIDIA API) ──────────────────────────────
# Get your API key at https://build.nvidia.com/
AI_API=

# ─── Logging (Discord Webhook) ─────────────────────────
# Console output will be forwarded to this webhook
WEBHOOK=

# ─── HuggingFace (AI Image Gen) ────────────────────────
HF_TOKEN=
