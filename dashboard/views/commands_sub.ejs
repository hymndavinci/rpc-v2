<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= category %> - Hymn+
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="app-shell page-loaded">

    <%- include('partials/super_button') %>

    <main class="main">
        <div class="main__inner">

    <div class="sub-container">
        <div class="coming-soon-box">
            <div class="icon">
                <% if(category.includes('Rpc')) { %> 🎮
                    <% } else if(category.includes('Reaction')) { %> ✨
                        <% } else if(category.includes('Mirror')) { %> 🔮
                            <% } else { %> 🚀 <% } %>
            </div>
            <h1>
                <%= category %>
            </h1>
            <p>We are working hard to bring this feature to life. Stay tuned!</p>
            <button type="button" class="btn-back" onclick="goBack()">← Go Back</button>
        </div>
    </div>

        </div>
    </main>

        <script>
            window.onload = () => document.body.style.opacity = '1';

            function goBack() {
                document.body.style.opacity = '0';
                setTimeout(() => {
                    window.location.href = '/commands';
                }, 300);
            }
        </script>
</body>

</html>
