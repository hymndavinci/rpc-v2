<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hymn+ Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/favicon.ico">
</head>

<body class="app-shell">

    <%- include('partials/super_button') %>

    <main class="main">
        <div class="main__inner">

            <header class="page-header">
                <div>
                    <p class="page-header__eyebrow">Overview</p>
                    <h1 class="page-header__title">Welcome back, <span class="accent"><%= user.username %></span></h1>
                    <p class="page-header__hint">Here's what's happening with your bot today.</p>
                </div>
                <div class="page-datetime" aria-live="polite">
                    <span id="liveTime">--:--</span>
                    <span id="liveDate"></span>
                </div>
            </header>

            <ul class="kpi-grid" role="list">
                <li class="kpi kpi--emerald">
                    <div class="kpi__label">Uptime</div>
                    <div class="kpi__value" id="uptimeValue">--</div>
                </li>
                <li class="kpi kpi--sky">
                    <div class="kpi__label">Status</div>
                    <div class="kpi__value" id="statusValue"><%= status === 'dnd' ? 'Do not disturb' : status === 'idle' ? 'Idle' : status === 'online' ? 'Online' : status === 'invisible' ? 'Invisible' : status %></div>
                </li>
                <li class="kpi kpi--amber">
                    <div class="kpi__label">Servers</div>
                    <div class="kpi__value"><%= guildCount %></div>
                </li>
                <li class="kpi kpi--rose">
                    <div class="kpi__label">Commands</div>
                    <div class="kpi__value"><%= commandCount %></div>
                </li>
                <li class="kpi kpi--violet">
                    <div class="kpi__label">Latency</div>
                    <div class="kpi__value" id="latencyValue"><%= latency >= 0 ? latency + 'ms' : 'N/A' %></div>
                </li>
            </ul>

            <div class="layout-split layout-split--dashboard">
                <section class="card dashboard-status-card">
                    <div class="card__header">
                        <p class="card__eyebrow">Presence</p>
                        <h2 class="card__title">Status settings</h2>
                    </div>
                    <div class="card__body dashboard-status-card__body">
                        <div class="identity">
                            <img src="<%= user.displayAvatarURL({ format: 'png', dynamic: true, size: 256 }) %>" alt="Avatar"
                                class="profile-avatar st-<%= status %>">
                            <div>
                                <div class="identity__name"><%= user.username %></div>
                                <div class="identity__meta">
                                    <span class="profile-status-dot <%= status %>"></span>
                                    #<%= user.discriminator %>
                                </div>
                            </div>
                        </div>

                        <form id="statusForm" action="/update-status" method="POST" class="settings-form">
                            <div class="form-group">
                                <label>Mode</label>
                                <div class="status-options">
                                    <label class="radio-label">
                                        <input type="radio" name="status" value="online" <%= status === 'online' ? 'checked' : '' %>>
                                        <span class="radio-btn online">Online</span>
                                    </label>
                                    <label class="radio-label">
                                        <input type="radio" name="status" value="idle" <%= status === 'idle' ? 'checked' : '' %>>
                                        <span class="radio-btn idle">Idle</span>
                                    </label>
                                    <label class="radio-label">
                                        <input type="radio" name="status" value="dnd" <%= status === 'dnd' ? 'checked' : '' %>>
                                        <span class="radio-btn dnd">DND</span>
                                    </label>
                                    <label class="radio-label">
                                        <input type="radio" name="status" value="invisible" <%= status === 'invisible' ? 'checked' : '' %>>
                                        <span class="radio-btn offline">Invisible</span>
                                    </label>
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Custom Message</label>
                                <input type="text" name="custom_status" class="input-field" placeholder="Playing with code..."
                                    value="<%= currentActivity %>">
                            </div>
                            <div class="form-group">
                                <label>Emoji</label>
                                <input type="text" name="emoji" class="input-field" placeholder="🍕 or <:name:id>"
                                    value="<%= currentEmoji %>">
                                <small class="hint">Paste emoji or use ID format for custom ones</small>
                            </div>
                            <button type="submit" id="updateStatusBtn" class="save-btn">
                                <i class="fas fa-check btn-ico" aria-hidden="true"></i>Update Status
                            </button>
                        </form>
                    </div>
                </section>

                <div class="layout-split__aside">
                    <section class="card">
                        <div class="card__header">
                            <p class="card__eyebrow">Shortcuts</p>
                            <h2 class="card__title">Quick actions</h2>
                        </div>
                        <div class="card__body card__body--pad-tiles">
                            <nav class="tiles-grid" aria-label="Quick actions">
                                <a href="/music" class="tile">
                                    <span class="tile__ico tile__ico--a" aria-hidden="true"><i class="fas fa-headphones"></i></span>
                                    <span>Music Player</span>
                                </a>
                                <a href="/ai" class="tile">
                                    <span class="tile__ico tile__ico--b" aria-hidden="true"><i class="fas fa-brain"></i></span>
                                    <span>AI Chat</span>
                                </a>
                                <a href="/commands/rpc" class="tile">
                                    <span class="tile__ico tile__ico--c" aria-hidden="true"><i class="fas fa-gamepad"></i></span>
                                    <span>Rich Presence</span>
                                </a>
                                <a href="/afk" class="tile">
                                    <span class="tile__ico tile__ico--d" aria-hidden="true"><i class="fas fa-moon"></i></span>
                                    <span>AFK System</span>
                                </a>
                                <a href="/quest" class="tile">
                                    <span class="tile__ico tile__ico--e" aria-hidden="true"><i class="fas fa-scroll"></i></span>
                                    <span>Quests</span>
                                </a>
                                <a href="/server-cloner" class="tile">
                                    <span class="tile__ico tile__ico--f" aria-hidden="true"><i class="fas fa-clone"></i></span>
                                    <span>Server Cloner</span>
                                </a>
                            </nav>
                        </div>
                    </section>

                    <section class="card dashboard-embed-card">
                        <div class="card__header">
                            <p class="card__eyebrow">Live</p>
                            <h2 class="card__title">Presence embed</h2>
                        </div>
                        <div class="card__body card__body--flush dashboard-embed-card__body">
                            <img src="https://lanyard.kyrie25.dev/api/443335216833101825?waveColor=000&waveSpoitifyColor=212121&gradient=000&borderRadius=25px&bg=fff"
    class="brand-image" id="brandImage" alt="Brand Status">
                        </div>
                    </section>
                </div>
            </div>

            <section class="feed" aria-labelledby="activity-heading">
                <div class="feed__header">
                    <h2 id="activity-heading">Recent activity</h2>
                    <span id="actCount"></span>
                </div>
                <div class="feed__body" id="actList" role="log" aria-live="polite">
                    <div class="act-empty">Loading activity...</div>
                </div>
            </section>
        </div>
    </main>

    <script>
        let uptimeSeconds = <%= uptimeSeconds %>;
        function formatUptime(s) {
            const d = Math.floor(s / 86400); s %= 86400;
            const h = Math.floor(s / 3600); s %= 3600;
            const m = Math.floor(s / 60);
            const sec = Math.floor(s % 60);
            if (d > 0) return `${d}d ${h}h ${m}m`;
            if (h > 0) return `${h}h ${m}m ${sec}s`;
            return `${m}m ${sec}s`;
        }
        function updateClock() {
            const now = new Date();
            document.getElementById('liveTime').innerText = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
            document.getElementById('liveDate').innerText = now.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
        }

        function tickUptimeClock() {
            uptimeSeconds++;
            if (!document.hidden) {
                document.getElementById('uptimeValue').innerText = formatUptime(uptimeSeconds);
                updateClock();
            }
        }
        setInterval(tickUptimeClock, 1000);
        document.getElementById('uptimeValue').innerText = formatUptime(uptimeSeconds);
        updateClock();

        document.getElementById('statusForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const btn = document.getElementById('updateStatusBtn');
            const origHTML = btn.innerHTML;
            btn.disabled = true;
            const data = Object.fromEntries(new FormData(this).entries());
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (res.ok) {
                    var allowedStatus = { online: 1, idle: 1, dnd: 1, invisible: 1 };
                    var raw = data.status;
                    var statusLabels = { online: 'Online', idle: 'Idle', dnd: 'Do not disturb', invisible: 'Invisible' };
                    var safeStatus =
                        typeof raw === 'string' && allowedStatus[raw] ? raw : '<%= status %>';
                    btn.classList.add('save-btn--flash-success');
                    btn.innerHTML = '<i class="fas fa-check btn-ico" aria-hidden="true"></i>Saved!';
                    document.getElementById('statusValue').innerText = statusLabels[safeStatus] || safeStatus;
                    const avatar = document.querySelector('.profile-avatar');
                    avatar.className = 'profile-avatar st-' + safeStatus;
                    const dot = document.querySelector('.profile-status-dot');
                    dot.className = 'profile-status-dot ' + safeStatus;
                } else {
                    btn.classList.add('save-btn--flash-error');
                    btn.innerHTML = '<i class="fas fa-xmark btn-ico" aria-hidden="true"></i>Failed';
                }
                setTimeout(function () {
                    btn.classList.remove('save-btn--flash-success', 'save-btn--flash-error');
                    btn.innerHTML = origHTML;
                    btn.disabled = false;
                }, 2000);
            } catch (err) {
                console.error(err);
                btn.disabled = false;
                btn.innerHTML = origHTML;
            }
        });

        async function loadLatency() {
            try {
                const res = await fetch('/api/latency');
                const data = await res.json();
                const el = document.getElementById('latencyValue');
                if (el) {
                    const ms = data.latency >= 0 ? data.latency : -1;
                    el.textContent = ms >= 0 ? ms + 'ms' : 'N/A';
                    el.style.color = ms < 0 ? '' : ms < 100 ? '#22c55e' : ms < 250 ? '#f59e0b' : '#ef4444';
                }
            } catch (e) { /* silent */ }
        }

        var latencyTimerId = null;
        async function loadActivity() {
            try {
                const res = await fetch('/api/logs');
                const logs = await res.json();
                const container = document.getElementById('actList');
                const counter = document.getElementById('actCount');
                if (!logs || logs.length === 0) {
                    container.innerHTML = '<div class="act-empty">No recent activity</div>';
                    counter.innerText = '0 events';
                    return;
                }
                counter.innerText = logs.length + ' events';
                container.innerHTML = logs.slice(0, 15).map(function (log) {
                    var u = escapeHtml(String(log.user != null ? log.user : ''));
                    var c = log.content
                        ? escapeHtml(String(log.content).substring(0, 60))
                        : '';
                    var t = escapeHtml(String(log.time != null ? log.time : ''));
                    return (
                        '<div class="act-item">' +
                        '<div class="act-dot"></div>' +
                        '<div class="act-text"><strong>' +
                        u +
                        '</strong> ' +
                        (c ? '— ' + c : '') +
                        '</div>' +
                        '<div class="act-time">' +
                        t +
                        '</div></div>'
                    );
                }).join('');
            } catch (e) {
                document.getElementById('actList').innerHTML = '<div class="act-empty">Failed to load activity</div>';
            }
        }
        var brandTimerId = null;
        var activityTimerId = null;
        function stopBackgroundUiPollers() {
            if (brandTimerId) { clearInterval(brandTimerId); brandTimerId = null; }
            if (activityTimerId) { clearInterval(activityTimerId); activityTimerId = null; }
            if (latencyTimerId) { clearInterval(latencyTimerId); latencyTimerId = null; }
        }
        function startBackgroundUiPollers() {
            if (document.hidden) return;
            stopBackgroundUiPollers();
            brandTimerId = setInterval(function () {
                var img = document.getElementById('brandImage');
                if (img) { img.src = img.src.split('&t=')[0] + '&t=' + Date.now(); }
            }, 20000);
            activityTimerId = setInterval(loadActivity, 30000);
            latencyTimerId = setInterval(loadLatency, 30000);
        }
        document.addEventListener('visibilitychange', function () {
            if (document.hidden) {
                stopBackgroundUiPollers();
            } else {
                updateClock();
                document.getElementById('uptimeValue').innerText = formatUptime(uptimeSeconds);
                loadActivity();
                startBackgroundUiPollers();
            }
        });

        loadActivity();
        loadLatency();
        startBackgroundUiPollers();
    </script>
</body>

</html>
